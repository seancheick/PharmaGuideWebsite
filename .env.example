# =============================================================================
# PharmaGuide Website — environment variables template
# Copy to `.env` (gitignored) for local dev.
# Add the same keys to Vercel project settings (Production + Preview).
# =============================================================================

# ─── Site URL (canonical for SEO) ────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://pharmaguide.io

# ─── Analytics ───────────────────────────────────────────────────────
# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ─── Search-engine ownership verification ────────────────────────────
# Paste the verification token (NOT the full meta tag) from each platform.
# Next.js emits the appropriate <meta> tag automatically when set.

# Google Search Console — https://search.google.com/search-console
# Pick "HTML tag" verification method, copy the `content="..."` value
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools — https://www.bing.com/webmasters
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Yandex Webmaster (optional — useful only if Russian SEO matters)
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=

# ─── Resend (email + waitlist) ───────────────────────────────────────
# Required — server boot throws if any of these three are missing.
# Get from https://resend.com/api-keys
RESEND_API_KEY=

# Audience IDs from https://resend.com/audiences
RESEND_AUDIENCE_BETA_ID=
RESEND_AUDIENCE_NEWSLETTER_ID=

# Sender + reply-to (must be on a verified domain). Optional —
# defaults to "PharmaGuide <hello@pharmaguide.io>" + "info@pharmaguide.io".
RESEND_FROM_EMAIL="PharmaGuide <hello@pharmaguide.io>"
RESEND_REPLY_TO_EMAIL=info@pharmaguide.io

# ─── Upstash (rate limiting) ─────────────────────────────────────────
# Required in production. Optional in dev (rate limiter falls back
# to allow-with-warning). Provision a free Redis database at
# https://console.upstash.com — pick "Global" or your nearest region.
# Copy "REST URL" and "REST Token" from the database dashboard.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
